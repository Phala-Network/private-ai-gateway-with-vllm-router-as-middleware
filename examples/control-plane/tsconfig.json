{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["esnext"],
    "types": ["node"],
    "resolveJsonModule": true,
    "outDir": "build",
    "rootDir": "src"
  },
  "include": ["src"]
}
