{
  "name": "private-ai-gateway-control",
  "version": "0.1.0",
  "description": "Minimal config-driven control plane (no DB) implementing the gateway<->control HTTP surface.",
  "private": true,
  "type": "module",
  "bin": "build/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --packages=external --outfile=build/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.3.3",
    "hono": "^4.6.10"
  },
  "devDependencies": {
    "@types/node": "20.8.3",
    "esbuild": "^0.24.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
